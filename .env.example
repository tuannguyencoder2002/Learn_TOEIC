# Sao chép thành .env.local khi chạy setup.bat (hoặc copy tay)
# PostgreSQL mặc định: user postgres, port 5432

DATABASE_URL=postgresql://postgres:tttt2002@localhost:5432/learn_toeic
DEFAULT_USERNAME=default

# Dong bo DB giua cac may (db-sync.bat). Tro toi 1 thu muc CHUNG ca 2 may deu thay
# (Google Drive da sync / o mang LAN). De trong = dung ./db-snapshot trong project.
# Vi du: SYNC_DIR=G:\My Drive\learn-toeic-db
SYNC_DIR=

# OpenAI API (tùy chọn — import AI / tạo đề / dịch từ vựng)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
